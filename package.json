{
  "name": "old-dragon-toolkit",
  "version": "0.17.0",
  "description": "Old Dragon 2 toolkit for Obsidian: interactive character sheets and rolls.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "ttrpg",
    "old-dragon",
    "rpg"
  ],
  "author": "Maicon-Lara",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
